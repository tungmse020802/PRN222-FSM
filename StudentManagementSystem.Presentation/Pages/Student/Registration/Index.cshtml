@page
@using StudentManagementSystem.Shared.Enums
@model StudentManagementSystem.Presentation.Pages.Student.Registration.IndexModel
@{
    ViewData["Title"] = "Course Registration";
}

<div class="page-toolbar">
    <div class="page-intro">
        <h1>Course Registration</h1>
        <p>Register or cancel course sections within the allowed semester window.</p>
    </div>
    <form method="get" class="filter-bar">
        <select asp-for="SemesterId" class="form-select filter-w-sm">
            @foreach (var semester in Model.Semesters)
            {
                <option value="@semester.SemesterId">@semester.SemesterCode - @semester.SemesterName</option>
            }
        </select>
        <input asp-for="SearchTerm" class="form-control filter-search" placeholder="Search section or subject" />
        <button type="submit" class="btn btn-outline-primary">Filter</button>
    </form>
</div>

<div class="row g-3 mb-3">
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase fw-semibold">Current registered credits</div>
                <div class="display-6 fw-semibold">@Model.CurrentCredits</div>
                <div class="text-muted small mt-2">Semester max: @(Model.SelectedSemester?.MaxCreditsPerStudent ?? 0) credits</div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between gap-3">
                    <div>
                        <div class="text-muted small text-uppercase fw-semibold">Study Recommendation</div>
                        <div class="h5 mt-2 mb-1">
                            @(Model.LatestRecommendation?.RiskLevel.ToString() ?? "Not generated")
                        </div>
                        <div class="text-muted small">
                            @if (Model.LatestRecommendation is null)
                            {
                                <span>No study plan has been generated for this semester yet.</span>
                            }
                            else
                            {
                                <span>Suggested load: @Model.LatestRecommendation.RecommendedCredits credits.</span>
                            }
                        </div>
                    </div>
                    <a asp-page="/Student/Recommendations/Index" asp-route-semesterId="@Model.SemesterId" class="btn btn-outline-primary align-self-start">Open</a>
                </div>
                <div class="small text-muted mt-3">Current engine is rule-based and updates after grades change.</div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <h2 class="h5">My Registered Sections</h2>
                <div class="d-flex flex-wrap gap-2 mt-3">
                    @foreach (var enrollment in Model.CurrentEnrollments.Where(x => x.Status == EnrollmentStatus.Registered))
                    {
                        <span class="badge bg-primary-subtle text-primary px-3 py-2">
                            @enrollment.CourseSection?.SectionCode - @enrollment.CourseSection?.SectionName
                        </span>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@if (Model.RegistrationSections.Count == 0)
{
    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <p class="text-muted mb-0">No course section matches the current semester and search filter.</p>
        </div>
    </div>
}
else
{
    <div class="section-grid">
        @foreach (var item in Model.RegistrationSections)
        {
            <div class="card border-0 shadow-sm section-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                        <div>
                            <div class="section-code">@item.Section.SectionCode</div>
                            <h2 class="h5 mb-1">@item.Section.SectionName</h2>
                            <div class="text-muted small">@item.Section.Subject?.SubjectCode - @item.Section.Subject?.SubjectName</div>
                        </div>
                        <span class="badge @item.StatusClass">@item.StatusText</span>
                    </div>

                    <div class="section-meta-grid">
                        <div class="section-meta-item">
                            <span class="section-meta-label">Lecturer</span>
                            <span class="section-meta-value">@item.LecturerName</span>
                        </div>
                        <div class="section-meta-item">
                            <span class="section-meta-label">Seats</span>
                            <span class="section-meta-value">@item.Section.CurrentCapacity / @item.Section.MaxCapacity</span>
                        </div>
                        <div class="section-meta-item">
                            <span class="section-meta-label">Class Start</span>
                            <span class="section-meta-value">@(item.ClassStartDate?.ToString("dd/MM/yyyy") ?? "--")</span>
                        </div>
                        <div class="section-meta-item">
                            <span class="section-meta-label">Registration</span>
                            <span class="section-meta-value">@item.RegistrationWindowLabel</span>
                        </div>
                    </div>

                    <div class="section-detail-stack mt-3">
                        <div>
                            <span class="section-meta-label">Slots</span>
                            <div class="section-detail-text">@item.ScheduleSummary</div>
                        </div>
                        <div>
                            <span class="section-meta-label">Rooms</span>
                            <div class="section-detail-text">@item.RoomSummary</div>
                        </div>
                        <div>
                            <span class="section-meta-label">Note</span>
                            <div class="section-detail-text text-muted">@item.AvailabilityNote</div>
                        </div>
                    </div>

                    <div class="section-actions mt-3">
                        @if (item.IsRegistered)
                        {
                            <form method="post" asp-page-handler="Cancel">
                                <input type="hidden" name="courseSectionId" value="@item.Section.CourseSectionId" />
                                <input type="hidden" name="semesterId" value="@Model.SemesterId" />
                                <input type="hidden" name="searchTerm" value="@Model.SearchTerm" />
                                <button type="submit" class="btn btn-outline-danger" disabled="@(!item.CanCancel)">Cancel Registration</button>
                            </form>
                        }
                        else
                        {
                            <form method="post" asp-page-handler="Register">
                                <input type="hidden" name="courseSectionId" value="@item.Section.CourseSectionId" />
                                <input type="hidden" name="semesterId" value="@Model.SemesterId" />
                                <input type="hidden" name="searchTerm" value="@Model.SearchTerm" />
                                <button type="submit" class="btn btn-primary" disabled="@(!item.CanRegister)">Register</button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
