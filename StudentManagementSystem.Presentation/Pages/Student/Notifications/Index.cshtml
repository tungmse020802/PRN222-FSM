@page
@model StudentManagementSystem.Presentation.Pages.Student.Notifications.IndexModel
@{
    ViewData["Title"] = "My Notifications";
}

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <div class="page-toolbar">
            <div class="page-intro">
                <h1>My Notifications</h1>
                <p>Academic alerts, registration updates, grades and study recommendations.</p>
            </div>
            <span class="text-muted small">@Model.Notifications.Count item(s)</span>
        </div>

        <div class="list-group">
            @foreach (var notification in Model.Notifications)
            {
                <div class="list-group-item d-flex justify-content-between align-items-start gap-3">
                    <div>
                        <div class="fw-semibold">@notification.Title</div>
                        <div class="text-muted small">@notification.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                        <div class="mt-2">@notification.Message</div>
                    </div>
                    <div class="text-end">
                        <div class="badge @(notification.IsRead ? "bg-secondary-subtle text-secondary" : "bg-primary-subtle text-primary")">
                            @(notification.IsRead ? "Read" : "Unread")
                        </div>
                        @if (!notification.IsRead)
                        {
                            <form method="post" asp-page-handler="Read" class="mt-2">
                                <input type="hidden" name="notificationId" value="@notification.NotificationId" />
                                <button type="submit" class="btn btn-sm btn-outline-primary">Mark read</button>
                            </form>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>
