@page
@model StudentManagementSystem.Presentation.Pages.Lecturer.Notifications.IndexModel
@{
    ViewData["Title"] = "Lecturer Notifications";
}

<div class="page-toolbar">
    <div class="page-intro">
        <h1>Lecturer Notifications</h1>
        <p>Send quick messages to a class and review the latest delivery history.</p>
    </div>
</div>

<div class="row g-3">
    <div class="col-xl-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h2 class="h5 mb-3">Send Class Notification</h2>
                <form method="post" asp-page-handler="Send">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Input.CourseSectionId" class="form-label">Course Section</label>
                        <select asp-for="Input.CourseSectionId" class="form-select">
                            @foreach (var courseSection in Model.Sections)
                            {
                                <option value="@courseSection.CourseSectionId">@courseSection.SectionCode - @courseSection.SectionName</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Title" class="form-label"></label>
                        <input asp-for="Input.Title" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.Message" class="form-label"></label>
                        <textarea asp-for="Input.Message" class="form-control" rows="4"></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary">Send notification</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-xl-8">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2 class="h5 mb-0">My Notifications</h2>
                    <span class="text-muted small">@Model.Notifications.Count item(s)</span>
                </div>

                <div class="list-group">
                    @foreach (var notification in Model.Notifications)
                    {
                        <div class="list-group-item d-flex justify-content-between align-items-start gap-3">
                            <div>
                                <div class="fw-semibold">@notification.Title</div>
                                <div class="text-muted small">@notification.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                                <div class="mt-2">@notification.Message</div>
                            </div>
                            <div class="text-end">
                                <div class="badge @(notification.IsRead ? "bg-secondary-subtle text-secondary" : "bg-primary-subtle text-primary")">
                                    @(notification.IsRead ? "Read" : "Unread")
                                </div>
                                @if (!notification.IsRead)
                                {
                                    <form method="post" asp-page-handler="Read" class="mt-2">
                                        <input type="hidden" name="notificationId" value="@notification.NotificationId" />
                                        <button type="submit" class="btn btn-sm btn-outline-primary">Mark read</button>
                                    </form>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
