@page
@using StudentManagementSystem.Shared.Enums
@model StudentManagementSystem.Presentation.Pages.Admin.Semesters.IndexModel
@{
    ViewData["Title"] = "Manage Semesters";
}

<div class="page-toolbar">
    <div class="page-intro">
        <h1>Semester Management</h1>
        <p>Configure semester timelines, registration windows and credit limits.</p>
    </div>
    <form method="get" class="filter-bar">
        <input asp-for="SearchTerm" class="form-control filter-search" placeholder="Search semester code, name or school year" />
        <button type="submit" class="btn btn-outline-primary">Search</button>
        <a asp-page="./Index" class="btn btn-outline-secondary">Reset</a>
    </form>
</div>

<div class="row g-3">
    <div class="col-xl-4">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h2 class="h5 mb-3">@(Model.EditId.HasValue ? "Update Semester" : "Create Semester")</h2>
                <form method="post" asp-page-handler="@(Model.EditId.HasValue ? "Update" : "Create")">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                    <input asp-for="Input.SemesterId" type="hidden" />

                    <div class="mb-3">
                        <label asp-for="Input.SemesterCode" class="form-label"></label>
                        <input asp-for="Input.SemesterCode" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.SemesterName" class="form-label"></label>
                        <input asp-for="Input.SemesterName" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.SchoolYear" class="form-label"></label>
                        <input asp-for="Input.SchoolYear" class="form-control" />
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Input.StartDate" class="form-label"></label>
                            <input asp-for="Input.StartDate" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Input.EndDate" class="form-label"></label>
                            <input asp-for="Input.EndDate" class="form-control" />
                        </div>
                    </div>

                    <div class="row g-3 mt-1">
                        <div class="col-md-6">
                            <label asp-for="Input.RegistrationStartDate" class="form-label"></label>
                            <input asp-for="Input.RegistrationStartDate" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Input.RegistrationEndDate" class="form-label"></label>
                            <input asp-for="Input.RegistrationEndDate" class="form-control" />
                        </div>
                    </div>

                    <div class="row g-3 mt-1">
                        <div class="col-md-6">
                            <label asp-for="Input.MaxCreditsPerStudent" class="form-label"></label>
                            <input asp-for="Input.MaxCreditsPerStudent" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Input.Status" class="form-label"></label>
                            <select asp-for="Input.Status" class="form-select" asp-items="Html.GetEnumSelectList<SemesterStatus>()"></select>
                        </div>
                    </div>

                    <div class="form-check form-switch my-4">
                        <input asp-for="Input.IsActive" class="form-check-input" />
                        <label asp-for="Input.IsActive" class="form-check-label"></label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">@(Model.EditId.HasValue ? "Save changes" : "Create semester")</button>
                        @if (Model.EditId.HasValue)
                        {
                            <a asp-page="./Index" asp-route-searchTerm="@Model.SearchTerm" class="btn btn-outline-secondary">Cancel</a>
                        }
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-xl-8">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Code</th>
                                <th>Name</th>
                                <th>School Year</th>
                                <th>Study Period</th>
                                <th>Registration</th>
                                <th>Status</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var semester in Model.Semesters)
                        {
                            <tr>
                                <td class="fw-semibold">@semester.SemesterCode</td>
                                <td>@semester.SemesterName</td>
                                <td>@semester.SchoolYear</td>
                                <td>@semester.StartDate.ToString("dd/MM/yyyy") - @semester.EndDate.ToString("dd/MM/yyyy")</td>
                                <td>@semester.RegistrationStartDate.ToString("dd/MM/yyyy") - @semester.RegistrationEndDate.ToString("dd/MM/yyyy")</td>
                                <td>
                                    <span class="badge bg-light text-dark">@semester.Status</span>
                                </td>
                                <td class="text-end">
                                    <a asp-page="./Index" asp-route-editId="@semester.SemesterId" asp-route-searchTerm="@Model.SearchTerm" class="btn btn-sm btn-outline-primary">Edit</a>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
