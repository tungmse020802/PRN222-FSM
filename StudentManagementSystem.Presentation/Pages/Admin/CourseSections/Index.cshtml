@page
@model StudentManagementSystem.Presentation.Pages.Admin.CourseSections.IndexModel
@{
    ViewData["Title"] = "Manage Course Sections";
}

<div class="page-toolbar">
    <div class="page-intro">
        <h1>Course Section Management</h1>
        <p>Open and manage course sections by semester, subject and lecturer.</p>
    </div>
    <form method="get" class="filter-bar">
        <select asp-for="SemesterFilter" class="form-select filter-w-sm">
            <option value="">All semesters</option>
            @foreach (var semester in Model.Semesters)
            {
                <option value="@semester.SemesterId">@semester.SemesterCode - @semester.SemesterName</option>
            }
        </select>
        <input asp-for="SearchTerm" class="form-control filter-search" placeholder="Search section code or subject" />
        <button type="submit" class="btn btn-outline-primary">Filter</button>
        <a asp-page="./Index" class="btn btn-outline-secondary">Reset</a>
    </form>
</div>

<div class="row g-3">
    <div class="col-xl-4">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h2 class="h5 mb-3">@(Model.EditId.HasValue ? "Update Course Section" : "Create Course Section")</h2>
                <form method="post" asp-page-handler="@(Model.EditId.HasValue ? "Update" : "Create")">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                    <input asp-for="Input.CourseSectionId" type="hidden" />

                    <div class="mb-3">
                        <label asp-for="Input.SectionCode" class="form-label"></label>
                        <input asp-for="Input.SectionCode" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.SectionName" class="form-label"></label>
                        <input asp-for="Input.SectionName" class="form-control" />
                        <span asp-validation-for="Input.SectionName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.SubjectId" class="form-label">Subject</label>
                        <select asp-for="Input.SubjectId" class="form-select">
                            @foreach (var subject in Model.Subjects)
                            {
                                <option value="@subject.SubjectId">@subject.SubjectCode - @subject.SubjectName</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.SemesterId" class="form-label">Semester</label>
                        <select asp-for="Input.SemesterId" class="form-select">
                            @foreach (var semester in Model.Semesters)
                            {
                                <option value="@semester.SemesterId">@semester.SemesterCode - @semester.SemesterName</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.LecturerId" class="form-label">Lecturer</label>
                        <select asp-for="Input.LecturerId" class="form-select">
                            @foreach (var lecturer in Model.Lecturers)
                            {
                                <option value="@lecturer.LecturerId">@lecturer.LecturerCode - @lecturer.UserAccount?.FullName</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.MaxCapacity" class="form-label"></label>
                        <input asp-for="Input.MaxCapacity" class="form-control" />
                    </div>

                    <div class="form-check form-switch mb-4">
                        <input asp-for="Input.IsOpen" class="form-check-input" />
                        <label asp-for="Input.IsOpen" class="form-check-label"></label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">@(Model.EditId.HasValue ? "Save changes" : "Create section")</button>
                        @if (Model.EditId.HasValue)
                        {
                            <a asp-page="./Index" asp-route-searchTerm="@Model.SearchTerm" asp-route-semesterFilter="@Model.SemesterFilter" class="btn btn-outline-secondary">Cancel</a>
                        }
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-xl-8">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Section</th>
                                <th>Class Name</th>
                                <th>Subject</th>
                                <th>Semester</th>
                                <th>Lecturer</th>
                                <th>Capacity</th>
                                <th>Open</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var courseSection in Model.CourseSections)
                        {
                            <tr>
                                <td class="fw-semibold">@courseSection.SectionCode</td>
                                <td>@courseSection.SectionName</td>
                                <td>@courseSection.Subject?.SubjectCode - @courseSection.Subject?.SubjectName</td>
                                <td>@courseSection.Semester?.SemesterCode</td>
                                <td>@courseSection.Lecturer?.UserAccount?.FullName</td>
                                <td>@courseSection.CurrentCapacity / @courseSection.MaxCapacity</td>
                                <td>
                                    <span class="badge @(courseSection.IsOpen ? "bg-success-subtle text-success" : "bg-secondary-subtle text-secondary")">
                                        @(courseSection.IsOpen ? "Open" : "Closed")
                                    </span>
                                </td>
                                <td class="text-end">
                                    <div class="d-inline-flex gap-2">
                                        <a asp-page="./Index" asp-route-editId="@courseSection.CourseSectionId" asp-route-searchTerm="@Model.SearchTerm" asp-route-semesterFilter="@Model.SemesterFilter" class="btn btn-sm btn-outline-primary">Edit</a>
                                        <form method="post" asp-page-handler="Toggle">
                                            <input type="hidden" name="courseSectionId" value="@courseSection.CourseSectionId" />
                                            <button type="submit" class="btn btn-sm btn-outline-dark">@(courseSection.IsOpen ? "Close" : "Open")</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
